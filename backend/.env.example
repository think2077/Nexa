# FunASR 配置
# 本地部署无需配置，如需指定模型路径可取消注释
# FUNASR_MODEL_DIR=./models

# LLM API 配置 (阿里云 DashScope - 通义千问)
DASHSCOPE_API_KEY=sk-xxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# TTS 配置
# edge-tts 免费无需 key，如需使用 OpenAI TTS 可配置
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxx

# 服务器配置
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8765

# 音频配置
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_DURATION=0.2  # 每帧音频时长 (秒)

# VAD 配置
VAD_THRESHOLD=0.5  # VAD 检测阈值
SPEECH_MIN_DURATION=0.5  # 最小语音持续时间 (秒)
SILENCE_MAX_DURATION=1.5  # 最大静音时长，超过则判定语句结束

# 日志配置
LOG_LEVEL=INFO
